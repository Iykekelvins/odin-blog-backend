{
	"name": "odin-blog-backend",
	"version": "1.0.0",
	"description": "A simple blog API",
	"main": "app.js",
	"scripts": {
		"dev": "nodemon app.js",
		"prisma-migrate": "npx prisma migrate dev --name init",
		"prisma-generate": "npx prisma generate",
		"prisma-studio": "npx prisma studio --config ./prisma.config.js",
		"prisma-init": "npx prisma init --datasource-provider postgresql --output ../generated/prisma --generator-provider prisma-client-js"
	},
