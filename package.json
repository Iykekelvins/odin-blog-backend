	"dependencies": {
		"@prisma/adapter-pg": "^7.7.0",
		"@prisma/client": "^7.7.0",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"pg": "^8.20.0",
		"prisma": "^7.7.0"
	}
}
